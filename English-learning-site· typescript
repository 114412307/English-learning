  improve: "改善、提升",
  challenge: "挑戰",
  practice: "練習",
  language: "語言",
  article: "文章",
  sentence: "句子",
  understand: "理解",
  learn: "學習",
  repeat: "重複",
  explain: "解釋",
  word: "單字",
